#!/usr/bin/env node
import { execSync, spawnSync } from 'node:child_process';
import { createWriteStream, readFileSync, writeFileSync, appendFileSync, rmSync, existsSync, mkdirSync, copyFileSync, chmodSync } from 'node:fs';
import { resolve, dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';
import { tmpdir, homedir } from 'node:os';
import https from 'node:https';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const root = resolve(__dirname, '..');

const VERSION = JSON.parse(readFileSync(resolve(root, 'package.json'), 'utf8')).version;
const REPO = 'saaandbite/pdfchips';

const arg = process.argv[2];
if (arg === 'uninstall') {
  runUninstall();
} else {
  runInstall().catch(err => {
    console.error(`\nError: ${err.message}`);
    process.exit(1);
  });
}

// ── Privilege detection ───────────────────────────────────────────────────────

function isRoot() {
  try { return process.getuid?.() === 0; } catch { return false; }
}

function hasSudo() {
  if (isRoot()) return true;
  const r = spawnSync('sudo', ['-n', 'true'], { stdio: 'ignore' });
  return r.status === 0;
}

/**
 * Try to run a command with sudo/root. If no sudo available, warn and return false.
 * @param {string[]} args
 * @returns {boolean} success
 */
function privRun(args) {
  try {
    if (isRoot()) {
      execSync(args.join(' '), { stdio: 'inherit' });
    } else {
      execSync(['sudo', ...args].join(' '), { stdio: 'inherit' });
    }
    return true;
  } catch (e) {
    const msg = e.message || '';
    if (msg.includes('sudoers') || msg.includes('not allowed') || msg.includes('sudo:')) {
      console.warn(`  ⚠  No sudo access. Cannot run: ${args.join(' ')}`);
      console.warn(`     Ask your admin to run this command manually.`);
    } else {
      console.warn(`  ⚠  Command failed: ${args.join(' ')}`);
    }
    return false;
  }
}

// ── Distro detection ──────────────────────────────────────────────────────────

function detectDistro() {
  try {
    const text = readFileSync('/etc/os-release', 'utf8');
    const get = key => {
      const m = text.match(new RegExp(`^${key}="?([^"\\n]+)"?`, 'm'));
      return m ? m[1].toLowerCase().trim() : '';
    };
    return { id: get('ID'), idLike: get('ID_LIKE') };
  } catch {
    return { id: '', idLike: '' };
  }
}

function getPackageType(id, idLike) {
  // Windows
  if (process.platform === 'win32') return 'nsis';
  const all = [id, ...idLike.split(/\s+/)].filter(Boolean);
  const is = (...names) => all.some(d => names.some(n => d.includes(n)));
  if (is('debian', 'ubuntu', 'linuxmint', 'pop', 'elementary', 'zorin', 'kali', 'raspbian', 'neon', 'deepin', 'mx')) return 'deb';
  if (is('fedora', 'rhel', 'centos', 'rocky', 'almalinux', 'ol', 'amzn', 'opensuse', 'sles', 'suse')) return 'rpm';
  return 'appimage';
}

// ── Download with redirect following ─────────────────────────────────────────

function download(url, dest) {
  return new Promise((resolve, reject) => {
    const follow = url => {
      https.get(url, { headers: { 'User-Agent': 'pdflinux-installer' } }, res => {
        if ([301, 302, 307, 308].includes(res.statusCode)) {
          return follow(res.headers.location);
        }
        if (res.statusCode !== 200) {
          return reject(new Error(
            `Download failed (HTTP ${res.statusCode}).\n` +
            `Make sure the GitHub Release for v${VERSION} exists:\n` +
            `https://github.com/${REPO}/releases`
          ));
        }
        const total = parseInt(res.headers['content-length'] || '0', 10);
        let received = 0;
        const file = createWriteStream(dest);
        res.on('data', chunk => {
          received += chunk.length;
          if (total) {
            const pct = Math.floor(received / total * 100);
            process.stdout.write(`\r  ${pct}%  (${(received / 1048576).toFixed(1)} / ${(total / 1048576).toFixed(1)} MB)`);
          }
        });
        res.pipe(file);
        file.on('finish', () => { file.close(); process.stdout.write('\n'); resolve(); });
        file.on('error', reject);
      }).on('error', reject);
    };
    follow(url);
  });
}

// ── System deps ───────────────────────────────────────────────────────────────

function installSystemDeps(type) {
  if (type === 'nsis') {
    console.log('\n  ℹ  Windows detected. Dependency tools (Ghostscript, Poppler, QPDF, Tesseract)');
    console.log('     must be installed via winget or Chocolatey if not present:');
    console.log('     winget install ArtifexSoftware.GhostScript');
    console.log('     winget install inkscape.inkscape  (or poppler via choco)');
    console.log('     winget install qpdf.qpdf');
    console.log('     winget install UB-Mannheim.TesseractOCR');
    console.log('     The installer will try to proceed without them for now.\n');
    return;
  }
  console.log('Installing PDF tools (Ghostscript, Poppler, QPDF, Tesseract)...');
  let ok = false;
  try {
    if (type === 'deb') {
      ok = privRun(['apt-get', 'install', '-y', 'ghostscript', 'poppler-utils', 'qpdf', 'tesseract-ocr']);
    } else if (type === 'rpm') {
      ok = privRun(['dnf', 'install', '-y', 'ghostscript', 'poppler-utils', 'qpdf', 'tesseract'])
        || privRun(['yum', 'install', '-y', 'ghostscript', 'poppler-utils', 'qpdf', 'tesseract']);
    } else if (existsSync('/usr/bin/pacman')) {
      ok = privRun(['pacman', '-Sy', '--noconfirm', 'ghostscript', 'poppler', 'qpdf', 'tesseract']);
    } else if (existsSync('/usr/bin/zypper')) {
      ok = privRun(['zypper', 'install', '-y', 'ghostscript', 'poppler-tools', 'qpdf', 'tesseract-ocr']);
    }
  } catch { ok = false; }

  if (!ok) {
    console.warn('  ⚠  Could not auto-install system deps.');
    console.warn('     Please install manually: ghostscript poppler-utils qpdf tesseract-ocr');
  }
}

// ── Install .deb ──────────────────────────────────────────────────────────────

function installDeb(tmp) {
  // Try system-wide install first
  const ok = privRun(['apt-get', 'install', '-y', `"${tmp}"`]);
  if (ok) return;

  // No-sudo fallback: extract binary with dpkg-deb
  console.log('  Trying user-level fallback (no sudo)...');
  const extractDir = join(tmpdir(), 'pdflinux_extract');
  const localBin = join(homedir(), '.local', 'bin');
  mkdirSync(localBin, { recursive: true });

  try {
    execSync(`dpkg-deb -x "${tmp}" "${extractDir}"`, { stdio: 'inherit' });
    const extracted = join(extractDir, 'usr', 'bin', 'pdflinux');
    if (existsSync(extracted)) {
      const dest = join(localBin, 'pdflinux');
      copyFileSync(extracted, dest);
      chmodSync(dest, 0o755);
      ensureLocalBinInPath(localBin);
      console.log(`  ✓ Installed to ${dest} (user install, no root needed)`);
      installDesktopFile(dest);
      return;
    }
  } catch (e) {
    console.warn(`  ⚠  dpkg-deb extraction failed: ${e.message}`);
  }

  console.error('\n  ✗ Could not install pdflinux.');
  console.error(`    Ask your system administrator to run:`);
  console.error(`      sudo apt-get install -y "${tmp}"`);
  process.exit(1);
}

// ── Install .rpm ──────────────────────────────────────────────────────────────

function installRpm(tmp) {
  const ok = privRun(['dnf', 'install', '-y', `"${tmp}"`])
          || privRun(['yum', 'install', '-y', `"${tmp}"`]);
  if (!ok) {
    console.error('\n  ✗ Could not install pdflinux (no sudo).');
    console.error(`    Ask your admin to run: sudo dnf install -y "${tmp}"`);
    process.exit(1);
  }
}

// ── Install .exe (NSIS / Windows) ────────────────────────────────────────────

function installNsis(tmp) {
  console.log(`  Launching Windows installer: ${tmp}`);
  console.log('  Follow the on-screen wizard to complete installation.');
  try {
    // Run the NSIS installer — it opens a GUI wizard
    execSync(`"${tmp}"`, { stdio: 'inherit' });
    console.log('  ✓ Installation wizard completed.');
  } catch (e) {
    console.warn(`  ⚠  Installer exited with non-zero status: ${e.message}`);
    console.warn('     If the app was installed, you can ignore this warning.');
  }
}

// ── Install AppImage (always user-level, no sudo) ─────────────────────────────

function installAppImage(src) {
  const localBin = join(homedir(), '.local', 'bin');
  mkdirSync(localBin, { recursive: true });
  const dest = join(localBin, 'pdf-chips');
  copyFileSync(src, dest);
  chmodSync(dest, 0o755);
  ensureLocalBinInPath(localBin);
  installDesktopFile(dest);
  console.log(`  ✓ Installed AppImage to ${dest}`);
}

// ── Desktop integration (user-level, no sudo) ─────────────────────────────────

function installDesktopFile(execPath) {
  try {
    const desktopDir = join(homedir(), '.local', 'share', 'applications');
    mkdirSync(desktopDir, { recursive: true });
    const iconSrc = resolve(root, 'src-tauri/icons/128x128.png');
    const iconDir = join(homedir(), '.local', 'share', 'icons', 'hicolor', '128x128', 'apps');
    mkdirSync(iconDir, { recursive: true });
    if (existsSync(iconSrc)) {
      copyFileSync(iconSrc, join(iconDir, 'pdf-chips.png'));
    }
    const desktop = [
      '[Desktop Entry]',
      'Type=Application',
      'Name=PDF & Chips',
      'Comment=Privacy-first PDF tools — runs 100% offline',
      `Exec=${execPath}`,
      'Icon=pdf-chips',
      'Categories=Office;Utility;',
      'Terminal=false',
      'StartupNotify=true',
    ].join('\n') + '\n';
    const desktopPath = join(desktopDir, 'pdf-chips.desktop');
    writeFileSync(desktopPath, desktop);
    try { execSync(`update-desktop-database "${desktopDir}" 2>/dev/null`, { stdio: 'ignore' }); } catch {}
    console.log('  ✓ Application menu shortcut added.');
  } catch (e) {
    console.warn(`  ⚠  Could not add desktop shortcut: ${e.message}`);
  }
}

function ensureLocalBinInPath(dir) {
  const shell = process.env.SHELL || '';
  let rc = '';
  if (shell.includes('bash')) rc = join(homedir(), '.bashrc');
  else if (shell.includes('zsh')) rc = join(homedir(), '.zshrc');
  if (rc && existsSync(rc)) {
    const content = readFileSync(rc, 'utf8');
    if (!content.includes(dir)) {
      appendFileSync(rc, `\nexport PATH="${dir}:$PATH"\n`);
      console.log(`  ✓ Added ${dir} to PATH in ${rc}`);
      console.log(`    Run: source ${rc}`);
    }
  }
}

// ── Install ───────────────────────────────────────────────────────────────────

async function runInstall() {
  const { id, idLike } = detectDistro();
  const type = getPackageType(id, idLike);

  const filename = {
    deb:      `pdf-chips_${VERSION}_amd64.deb`,
    rpm:      `pdf-chips_${VERSION}_x86_64.rpm`,
    appimage: `pdf-chips_${VERSION}_amd64.AppImage`,
    nsis:     `PDF.and.Chips_${VERSION}_x64-setup.exe`,
  }[type];

  const url = `https://github.com/${REPO}/releases/download/v${VERSION}/${filename}`;
  const tmp = join(tmpdir(), filename);

  console.log(`\nPDF & Chips v${VERSION} Installer`);
  if (type === 'nsis') {
    console.log(`Platform: Windows`);
    console.log(`Package : NSIS installer (.exe)`);
  } else {
    console.log(`Distro  : ${id || 'unknown'}${idLike ? ` (like ${idLike})` : ''}`);
    console.log(`Package : ${type.toUpperCase()}`);
  }

  if (!hasSudo() && !isRoot() && type !== 'nsis') {
    console.warn(`\n  ⚠  No sudo access detected.`);
    console.warn(`     System-level installation may not be possible.`);
    if (type !== 'appimage') {
      console.warn(`     Will attempt user-level fallback (${homedir()}/.local/bin).`);
    }
    console.log('');
  }

  console.log(`\nDownloading ${filename}...`);
  await download(url, tmp);

  installSystemDeps(type);

  console.log(`\nInstalling pdf-chips...`);
  if (type === 'nsis') {
    installNsis(tmp);
  } else if (type === 'deb') {
    installDeb(tmp);
  } else if (type === 'rpm') {
    installRpm(tmp);
  } else {
    installAppImage(tmp);
  }

  console.log(`\n✓ PDF & Chips installed successfully!`);
  if (type === 'nsis') {
    console.log(`  Find it in your Start Menu or Desktop.\n`);
  } else {
    console.log(`  Run from terminal : pdf-chips`);
    console.log(`  Or find it in your application menu.\n`);
  }
}

// ── Uninstall ─────────────────────────────────────────────────────────────────

function runUninstall() {
  const { id, idLike } = detectDistro();
  const type = getPackageType(id, idLike);
  const localBin = join(homedir(), '.local', 'bin', 'pdf-chips');

  console.log('Uninstalling pdf-chips...');

  // Remove user-level install first (no sudo needed)
  if (existsSync(localBin)) {
    try {
      rmSync(localBin);
      console.log(`  ✓ Removed ${localBin}`);
    } catch (e) {
      console.warn(`  Could not remove ${localBin}: ${e.message}`);
    }
  }

  // Remove desktop file
  const desktopFile = join(homedir(), '.local', 'share', 'applications', 'pdf-chips.desktop');
  if (existsSync(desktopFile)) {
    try { rmSync(desktopFile); } catch {}
  }

  // Remove system-level install (if sudo available)
  try {
    if (type === 'deb') {
      privRun(['apt-get', 'remove', '-y', 'pdf-chips']);
    } else if (type === 'rpm') {
      privRun(['dnf', 'remove', '-y', 'pdf-chips']) || privRun(['yum', 'remove', '-y', 'pdf-chips']);
    } else {
      privRun(['rm', '-rf', '/opt/pdf-chips', '/usr/local/bin/pdf-chips',
        '/usr/share/applications/pdf-chips.desktop',
        '/usr/share/icons/hicolor/128x128/apps/pdf-chips.png']);
    }
  } catch { /* ignore */ }

  console.log('pdf-chips has been uninstalled.');
}
