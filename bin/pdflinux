#!/usr/bin/env node
import { spawnSync } from 'node:child_process';
import { resolve, dirname } from 'node:path';
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

const root = resolve(__dirname, '..');
const installScript = resolve(root, 'install.sh');
const uninstallScript = resolve(root, 'uninstall.sh');

const args = process.argv.slice(2);
const cmd = args[0];

if (cmd === 'uninstall') {
    if (!existsSync(uninstallScript)) {
        console.error('uninstall.sh not found.');
        process.exit(1);
    }
    const result = spawnSync('bash', [uninstallScript], { stdio: 'inherit' });
    process.exit(result.status ?? 0);
}

// Default: install
if (!existsSync(installScript)) {
    console.error('install.sh not found.');
    process.exit(1);
}

const result = spawnSync('bash', [installScript], { stdio: 'inherit', cwd: root });
process.exit(result.status ?? 0);
